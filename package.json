{
  "name": "discord-bot",
  "version": "0.2.0-dev.2",
  "description": "Discord bot profesional con TypeScript, DDD pragmático, hexagonal y CQRS-like",
  "main": "dist/main.js",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "register:commands": "tsx ./src/scripts/register-slash-commands.ts",
    "check": "npm run lint && npm run test && npm run build",
    "commitlint": "commitlint --last --verbose",
    "release": "semantic-release",
    "release:dry-run": "semantic-release --dry-run --no-ci"
  },
  "dependencies": {
    "@discord-player/downloader": "^3.0.2",
    "@discord-player/extractor": "^7.2.0",
    "@napi-rs/canvas": "^0.1.66",
    "@snazzah/davey": "^0.1.10",
    "discord-player": "^7.2.0",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.7",
    "ffmpeg-static": "^5.3.0",
    "mediaplex": "^1.0.0",
    "mongodb": "^6.16.0",
    "opusscript": "^0.1.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/node": "^22.13.14",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "mongodb-memory-server": "^10.1.4",
    "prettier": "^3.5.3",
    "semantic-release": "^25.0.3",
    "tsc-alias": "^1.8.15",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
